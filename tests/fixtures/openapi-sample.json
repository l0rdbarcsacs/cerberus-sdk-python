{
  "openapi": "3.1.0",
  "info": {
    "title": "Cerberus Compliance API (sample)",
    "version": "0.1.0",
    "description": "Minimal stub used by SDK tests for offline codegen + client smoke tests."
  },
  "servers": [
    { "url": "https://mock.test/v1", "description": "Test mock" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Health": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["ok", "degraded"] },
          "version": { "type": "string" }
        }
      },
      "Entity": {
        "type": "object",
        "required": ["id", "rut", "legal_name"],
        "properties": {
          "id": { "type": "string" },
          "rut": { "type": "string" },
          "legal_name": { "type": "string" }
        }
      },
      "Problem": {
        "type": "object",
        "description": "RFC 7807 problem document",
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" },
          "instance": { "type": "string" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Health" }
              }
            }
          }
        }
      }
    },
    "/entities/{id}": {
      "get": {
        "summary": "Retrieve an entity by id",
        "operationId": "getEntity",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Entity" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/Problem" }
              }
            }
          }
        }
      }
    }
  }
}
